<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Admin Dashboard"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAdminHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Placeholder cho /api/admin/stats va /api/admin/users" />

            <EditText
                android:id="@+id/etTargetId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Nhap ID (userId/questionId)"
                android:inputType="number" />

            <EditText
                android:id="@+id/etPayload"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                android:gravity="top|start"
                android:hint="Nhap JSON payload cho create/update"
                android:inputType="textMultiLine"
                android:minLines="4" />

            <Button
                android:id="@+id/btnRefreshDashboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Refresh dashboard" />

            <Button
                android:id="@+id/btnAdminAllExams"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Load all exams" />

            <Button
                android:id="@+id/btnCreateUser"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Create user (payload)" />

            <Button
                android:id="@+id/btnGetUserById"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Get user by ID" />

            <Button
                android:id="@+id/btnUpdateUser"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Update user by ID + payload" />

            <Button
                android:id="@+id/btnDeleteUser"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Delete user by ID" />

            <Button
                android:id="@+id/btnLoadQuestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Load questions page 1" />

            <Button
                android:id="@+id/btnGetQuestionById"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Get question by ID" />

            <Button
                android:id="@+id/btnLoadImportantQuestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Load important questions" />

            <Button
                android:id="@+id/btnCreateQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Create question (payload)" />

            <Button
                android:id="@+id/btnUpdateQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Update question by ID + payload" />

            <Button
                android:id="@+id/btnDeleteQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Delete question by ID" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Danh sach du lieu (toi gian)" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAdminData"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:overScrollMode="never"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
